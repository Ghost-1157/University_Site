# ── Cloud hosting ────────────────────────────────────────────────────────────
# Render and Railway inject DATABASE_URL automatically when you attach a
# managed PostgreSQL database.  Set this and the individual DB_* vars below
# are ignored.
DATABASE_URL=

# ── Local development ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=practice_for_practice
DB_USER=postgres
DB_PASSWORD=

# Set to "true" when the PostgreSQL server requires SSL (always required on
# Render/Railway managed databases – handled automatically via DATABASE_URL).
DB_SSL=false

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud platforms set PORT automatically; leave blank for local (defaults to 3000).
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leave blank (or set to *) to allow all origins.
# Set to your frontend URL when the frontend is hosted separately, e.g.:
#   FRONTEND_ORIGIN=https://my-university-site.onrender.com
FRONTEND_ORIGIN=

# ── Database table ────────────────────────────────────────────────────────────
# Override the default table name used by the API.
UNIFIED_UNIVERSITIES_TABLE=university_table_final
